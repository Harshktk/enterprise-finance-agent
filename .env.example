# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://finance_user:finance_pass@db:5432/finance_db

# ── LLM Provider ──────────────────────────────────────────────────────────
# Options: mock | groq | anthropic | ollama
# Use "mock" for demos with no API key required
# Use "groq" for free cloud LLM (get key at console.groq.com)
# Use "anthropic" for Claude (get key at console.anthropic.com)
# Use "ollama" only for local development
LLM_PROVIDER=mock

# ── Groq (free — recommended for cloud deployment) ────────────────────────
GROQ_API_KEY=

# ── Anthropic ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Ollama (local only) ───────────────────────────────────────────────────
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=mistral
